cat > _pkgdown.yml <<'EOF'
url: https://mghotbi.github.io/RRI/

template:
  bootstrap: 5
  bootswatch: flatly

home:
  title: "RRI"
  description: >
    Holobiont Redox Resilience Index

navbar:
  structure:
    left: [intro, reference, articles]
    right: [github]

reference:
  - title: Core workflow
    contents:
      - simulate_redox_holobiont
      - rri_pipeline_st
      - plot_RRI_ternary

  - title: Recovery metrics
    contents:
      - rri_recovery_metrics
      - rri_metric_table
      - plot_rri_recovery_landscape

  - title: Diagnostics and sensitivity
    contents:
      - rri_latent_correlation
      - rri_compensation_index
      - rri_sensitivity

  - title: Theme
    contents:
      - theme_ems

articles:
  - title: Vignettes
    navbar: ~
    contents:
      - RRI
EOF

url: https://mghotbi.github.io/RRI/

template:
